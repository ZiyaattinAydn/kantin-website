rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function validEvent() {
      return request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.branch in ['alsancak', 'atakent', 'both']
        && request.resource.data.status in ['draft', 'published']
        && request.resource.data.startAt is timestamp
        && request.resource.data.endAt is timestamp
        && request.resource.data.endAt > request.resource.data.startAt;
    }

    match /events/{eventId} {
      allow get, list: if resource.data.status == 'published' || isAdmin();
      allow create, update: if isAdmin() && validEvent();
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }
  }
}
